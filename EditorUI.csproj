    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>1.0.0</Version>
    <Authors>Justin Emerson</Authors>
    <Description>Immediate-mode editor UI framework for MonoGame.</Description>
